#!/usr/bin/env bash
{{ if ne .de "gnome" }}exit 0{{ end }}
# Install and configure GNOME extensions (tiling, pop-shell)
# Migrated from Temp/configure-tiling-shell.sh

# Tiling Shell Configuration for GNOME 49.5
# Fixes common issues and sets up Vim-style keybindings

set -euo pipefail

echo "🪟 Configuring Tiling Shell..."

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# ============================================
# 1. DISABLE GNOME'S DEFAULT TILING
# ============================================
echo -e "${BLUE}🔧 Disabling GNOME default tiling...${NC}"

# Disable edge tiling (this conflicts with Tiling Shell)
gsettings set org.gnome.mutter edge-tiling false

# Disable default tiling keybindings
gsettings set org.gnome.mutter.keybindings toggle-tiled-left "[]"
gsettings set org.gnome.mutter.keybindings toggle-tiled-right "[]"
gsettings set org.gnome.desktop.wm.keybindings maximize "[]"
gsettings set org.gnome.desktop.wm.keybindings unmaximize "[]"

echo -e "${GREEN}✓ GNOME default tiling disabled${NC}"

# ============================================
# 2. FIX CONFLICTING KEYBINDINGS
# ============================================
echo -e "${BLUE}⌨️ Setting up Vim-style workspace navigation...${NC}"

# Clear conflicting keybindings
gsettings set org.gnome.desktop.wm.keybindings begin-move "[]"
gsettings set org.gnome.desktop.wm.keybindings minimize "[]"

# Set Vim-style workspace navigation (Super + h/j/k/l)
gsettings set org.gnome.desktop.wm.keybindings switch-to-workspace-left "['<Super>h']"
gsettings set org.gnome.desktop.wm.keybindings switch-to-workspace-right "['<Super>l']"
gsettings set org.gnome.desktop.wm.keybindings switch-to-workspace-up "['<Super>k']"
gsettings set org.gnome.desktop.wm.keybindings switch-to-workspace-down "['<Super>j']"

echo -e "${GREEN}✓ Workspace navigation configured${NC}"

# ============================================
# 3. CONFIGURE TILING SHELL SETTINGS
# ============================================
echo -e "${BLUE}⚙️ Configuring Tiling Shell settings...${NC}"

# Note: Using dconf because gsettings schema might not be available
# Proper GVariant syntax for dconf
dconf write /org/gnome/shell/extensions/tilingshell/enable-autotiling "true"
dconf write /org/gnome/shell/extensions/tilingshell/enable-snap-assistant "true"
dconf write /org/gnome/shell/extensions/tilingshell/inner-gaps "uint32 8"
dconf write /org/gnome/shell/extensions/tilingshell/outer-gaps "uint32 8"
dconf write /org/gnome/shell/extensions/tilingshell/show-indicator "false"

# Clear the overridden-settings that might be causing conflicts
dconf write /org/gnome/shell/extensions/tilingshell/overridden-settings "'{}'"

echo -e "${GREEN}✓ Tiling Shell settings applied${NC}"

# ============================================
# 4. CONFIGURE TILING SHELL KEYBINDINGS
# ============================================
echo -e "${BLUE}🎹 Configuring Tiling Shell keybindings...${NC}"

# Enable move keybindings
dconf write /org/gnome/shell/extensions/tilingshell/enable-move-keybindings "true"

# Enable focus mode
dconf write /org/gnome/shell/extensions/tilingshell/enable-focus-mode "true"

# Restore window size when untiled
dconf write /org/gnome/shell/extensions/tilingshell/restore-window-original-size "true"

# Set Vim-style keybindings for window movement (Super + Shift + h/j/k/l)
dconf write /org/gnome/shell/extensions/tilingshell/move-window-left "['<Super><Shift>h']"
dconf write /org/gnome/shell/extensions/tilingshell/move-window-down "['<Super><Shift>j']"
dconf write /org/gnome/shell/extensions/tilingshell/move-window-up "['<Super><Shift>k']"
dconf write /org/gnome/shell/extensions/tilingshell/move-window-right "['<Super><Shift>l']"

# Set focus window keybindings (Super + Ctrl + h/j/k/l)
dconf write /org/gnome/shell/extensions/tilingshell/focus-window-left "['<Super><Control>h']"
dconf write /org/gnome/shell/extensions/tilingshell/focus-window-down "['<Super><Control>j']"
dconf write /org/gnome/shell/extensions/tilingshell/focus-window-up "['<Super><Control>k']"
dconf write /org/gnome/shell/extensions/tilingshell/focus-window-right "['<Super><Control>l']"

# Center window (Super + Shift + c)
dconf write /org/gnome/shell/extensions/tilingshell/move-window-center "['<Super><Shift>c']"

echo -e "${GREEN}✓ Tiling Shell keybindings configured${NC}"
echo ""
echo "   Window movement:      Super + Shift + h/j/k/l"
echo "   Focus window:         Super + Ctrl + h/j/k/l"
echo "   Center window:        Super + Shift + c"

# ============================================
# 5. RESTART GNOME SHELL TO APPLY
# ============================================
echo ""
echo -e "${YELLOW}📝 Important: You need to restart GNOME Shell for changes to take effect${NC}"
echo ""
echo "   Option 1: Log out and log back in (Wayland)"
echo "   Option 2: Alt+F2, type 'r', press Enter (X11 only)"
echo ""

# ============================================
# VERIFICATION
# ============================================
echo -e "${BLUE}📋 Current Configuration:${NC}"
echo "   GNOME Edge Tiling: $(gsettings get org.gnome.mutter edge-tiling)"
echo "   Workspace Left:    $(gsettings get org.gnome.desktop.wm.keybindings switch-to-workspace-left)"
echo "   Workspace Right:   $(gsettings get org.gnome.desktop.wm.keybindings switch-to-workspace-right)"
echo "   Workspace Up:      $(gsettings get org.gnome.desktop.wm.keybindings switch-to-workspace-up)"
echo "   Workspace Down:    $(gsettings get org.gnome.desktop.wm.keybindings switch-to-workspace-down)"

echo ""
echo -e "${GREEN}✅ Tiling Shell configuration complete!${NC}"
echo ""
echo "🧪 Test it:"
echo "   1. Restart GNOME Shell (logout/login)"
echo "   2. Open a window"
echo "   3. Drag it to a screen edge - Snap Assistant should appear"
echo "   4. Use Super + Shift + h/j/k/l to tile windows"
echo ""
echo "📋 Keybindings Summary:"
echo "   Workspace navigation:  Super + h/j/k/l"
echo "   Move window:           Super + Shift + h/j/k/l"
echo "   Focus window:          Super + Ctrl + h/j/k/l"
echo "   Center window:         Super + Shift + c"
