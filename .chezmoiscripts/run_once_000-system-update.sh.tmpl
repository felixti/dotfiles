#!/usr/bin/env bash
{{ if eq .chezmoi.os "darwin" }}exit 0{{ end }}
# Initial system update only (brew/cargo not installed yet)
# Numbering 000- ensures it runs first, before all other run_once scripts
set -euo pipefail

echo "═══════════════════════════════════════"
echo "  Initial System Update"
echo "═══════════════════════════════════════"

# Platform-specific system update only
{{- if eq .flavor "fedora-atomic" }}
echo "→ Fedora Atomic: ujust update..."
ujust update
{{- else if eq .flavor "fedora" }}
echo "→ Fedora: dnf update..."
sudo dnf update -y
{{- else if eq .flavor "arch" }}
echo "→ Arch: pacman keyring + paru..."
sudo pacman -Sy archlinux-keyring && paru -Syu --noconfirm
{{- else if eq .flavor "debian" }}
echo "→ Debian/Ubuntu: apt update..."
sudo apt update && sudo apt upgrade -y
{{- end }}

echo "═══════════════════════════════════════"
echo "  ✓ System packages updated"
echo "═══════════════════════════════════════"
echo ""
echo "Note: Run 'update' after bootstrap completes for full update"
