#!/bin/bash
{{ if ne .de "gnome" }}exit 0{{ end }}
# Install Catppuccin Mocha theme for GNOME
# Migrated from Temp/setup-catppuccin-gnome49.sh

# Catppuccin Mocha Theme Setup for GNOME 49.5 on Fedora 43 Atomic (Bluefin)
# Complete theming solution for GTK3, GTK4/Libadwaita, GNOME Shell, Icons, and Cursors

# Don't exit on error - handle errors manually for better UX
# set -e

echo "🎨 Setting up Catppuccin Mocha on GNOME 49.5..."

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Theme configuration
THEME_NAME="Catppuccin-Mauve-Dark-Macchiato"
ACCENT_COLOR="mauve"  # Options: default, blue, flamingo, green, grey, lavender, maroon, mauve, peach, pink, red, rosewater, sapphire, sky, teal, yellow, all

# Create directories
mkdir -p ~/.themes ~/.config/gtk-4.0 ~/.icons ~/.local/share/icons ~/.local/share/gnome-shell/extensions

# ============================================
# CHECK PREREQUISITES
# ============================================
echo -e "${BLUE}🔍 Checking prerequisites...${NC}"

# Check if running on Atomic
if [ -f /run/ostree-booted ]; then
    echo -e "${BLUE}   ✓ Running on ostree-based system (Bluefin/Atomic)${NC}"
fi

# Check for required packages
if ! command -v sassc &> /dev/null; then
    echo -e "${YELLOW}⚠ sassc not found. Install with:${NC}"
    echo "   rpm-ostree install sassc gtk-murrine-engine gnome-themes-extra"
    echo "   Then reboot and run this script again."
fi

# ============================================
# 1. GTK Theme (Catppuccin Mocha)
# ============================================
echo -e "${BLUE}📦 Installing Catppuccin GTK Theme...${NC}"

cd /tmp
rm -rf Catppuccin-GTK-Theme
git clone --depth 1 https://github.com/Fausto-Korpsvart/Catppuccin-GTK-Theme.git
cd Catppuccin-GTK-Theme/themes

# Install with all tweaks for GNOME 49
# Tweaks: macchiato (color scheme), macos (window buttons), outline (2px border), float (floating panel)
./install.sh -d ~/.themes -t "$ACCENT_COLOR" --tweaks macchiato macos outline float -l

if [ -d "$HOME/.themes/$THEME_NAME" ]; then
    echo -e "${GREEN}✓ GTK theme installed: $THEME_NAME${NC}"
else
    # Try to find actual theme name
    THEME_NAME=$(ls ~/.themes/ | grep -i "catppuccin.*mocha" | head -1)
    if [ -z "$THEME_NAME" ]; then
        THEME_NAME="Catppuccin-Mocha"
    fi
    echo -e "${GREEN}✓ GTK theme installed: $THEME_NAME${NC}"
fi

# ============================================
# 2. Icons (Papirus + Catppuccin folders)
# ============================================
echo -e "${BLUE}🎭 Installing Papirus Icons...${NC}"

cd /tmp
# Install Papirus icons using the official install script
echo -e "${BLUE}   Downloading Papirus install script...${NC}"
wget -qO- https://raw.githubusercontent.com/PapirusDevelopmentTeam/papirus-icon-theme/master/install.sh | DEST_DIR="$HOME/.icons" sh || {
    echo -e "${YELLOW}⚠ Script install failed, trying direct download...${NC}"
    # Fallback: download release tarball
    wget -q --show-progress -O papirus-icon-theme.tar.gz "https://github.com/PapirusDevelopmentTeam/papirus-icon-theme/archive/refs/tags/20250501.tar.gz"
    tar -xzf papirus-icon-theme.tar.gz
    # Build and install
    cd papirus-icon-theme-20250501
    make -j$(nproc) 2>/dev/null || true
    mkdir -p ~/.icons
    cp -r Papirus* ~/.icons/ 2>/dev/null || true
    cd /tmp
    rm -rf papirus-icon-theme.tar.gz papirus-icon-theme-20250501
}

echo -e "${BLUE}📁 Applying Catppuccin folder colors...${NC}"
cd /tmp
rm -rf papirus-folders
git clone --depth 1 https://github.com/catppuccin/papirus-folders.git
cd papirus-folders
# Apply folder colors directly
./papirus-folders -t mocha --theme Papirus-Dark 2>/dev/null || ./papirus-folders -t mocha 2>/dev/null || echo -e "${YELLOW}⚠ Folder colors may need manual application${NC}"

echo -e "${GREEN}✓ Icons installed${NC}"

# ============================================
# 3. Cursor Theme (Catppuccin)
# ============================================
echo -e "${BLUE}🖱️ Installing Catppuccin Cursors...${NC}"

cd /tmp
rm -rf cursors
git clone --depth 1 https://github.com/catppuccin/cursors.git
cd cursors
# Build and install cursors
make -j$(nproc) 2>/dev/null || true
# Try install script first
if [ -f "./install.sh" ]; then
    ./install.sh
else
    # Manual install
    mkdir -p ~/.icons
    cp -r dist/* ~/.icons/ 2>/dev/null || cp -r themes/* ~/.icons/ 2>/dev/null || true
fi

echo -e "${GREEN}✓ Cursors installed${NC}"

# ============================================
# 4. GNOME Shell - User Themes Extension
# ============================================
echo -e "${BLUE}🔌 Checking User Themes extension...${NC}"

# Check if User Themes is installed and enabled
if ! gnome-extensions list | grep -q "user-theme"; then
    echo -e "${YELLOW}⚠ User Themes extension not found${NC}"
    echo -e "${BLUE}   Install with: ujust install-gnome-extension user-themes${NC}"
    echo "   Or via Extension Manager from Flathub"
else
    gnome-extensions enable user-theme@gnome-shell-extensions.gcampax.github.com 2>/dev/null || true
    echo -e "${GREEN}✓ User Themes extension enabled${NC}"
fi

# ============================================
# 5. Apply GNOME Settings
# ============================================
echo -e "${BLUE}⚙️ Applying GNOME 49 settings...${NC}"

# Detect the actual theme name
if [ ! -d "$HOME/.themes/$THEME_NAME" ]; then
    THEME_NAME=$(ls ~/.themes/ | grep -i "catppuccin.*mocha" | head -1 || echo "Catppuccin-Mocha")
fi

# Apply themes via gsettings
gsettings set org.gnome.desktop.interface gtk-theme "$THEME_NAME" 2>/dev/null || \
    echo -e "${YELLOW}⚠ Could not set GTK theme${NC}"

gsettings set org.gnome.desktop.interface icon-theme "Papirus-Dark" 2>/dev/null || \
    gsettings set org.gnome.desktop.interface icon-theme "Papyrus" 2>/dev/null || \
    echo -e "${YELLOW}⚠ Could not set icon theme${NC}"

gsettings set org.gnome.desktop.interface cursor-theme "catppuccin-mocha-cursors" 2>/dev/null || \
    echo -e "${YELLOW}⚠ Could not set cursor theme${NC}"

# Set dark mode
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

# Set accent color for GNOME 49+
gsettings set org.gnome.desktop.interface accent-color 'purple' 2>/dev/null || true

# Set GNOME Shell theme
gsettings set org.gnome.shell.extensions.user-theme name "$THEME_NAME" 2>/dev/null || \
    echo -e "${YELLOW}⚠ Could not set shell theme (User Themes extension may not be ready)${NC}"

echo -e "${GREEN}✓ GNOME settings applied${NC}"

# ============================================
# 6. GTK4/Libadwaita Support
# ============================================
echo -e "${BLUE}🔗 Configuring GTK4/Libadwaita support...${NC}"

# Ensure proper symlinks for libadwaita
if [ -d "$HOME/.themes/$THEME_NAME/gtk-4.0" ]; then
    rm -f ~/.config/gtk-4.0/gtk.css 2>/dev/null || true
    rm -f ~/.config/gtk-4.0/gtk-dark.css 2>/dev/null || true
    rm -rf ~/.config/gtk-4.0/assets 2>/dev/null || true
    
    ln -sf ~/.themes/$THEME_NAME/gtk-4.0/gtk.css ~/.config/gtk-4.0/gtk.css
    ln -sf ~/.themes/$THEME_NAME/gtk-4.0/gtk-dark.css ~/.config/gtk-4.0/gtk-dark.css
    ln -sf ~/.themes/$THEME_NAME/gtk-4.0/assets ~/.config/gtk-4.0/assets 2>/dev/null || true
    
    echo -e "${GREEN}✓ GTK4 theme linked${NC}"
fi

# ============================================
# 7. Flatpak Theming
# ============================================
echo -e "${BLUE}📦 Configuring Flatpak theming...${NC}"

# User overrides
flatpak override --user --filesystem=$HOME/.themes 2>/dev/null || true
flatpak override --user --filesystem=$HOME/.icons 2>/dev/null || true
flatpak override --user --filesystem=$HOME/.local/share/icons 2>/dev/null || true
flatpak override --user --filesystem=xdg-config/gtk-4.0 2>/dev/null || true
flatpak override --user --filesystem=xdg-config/gtk-3.0 2>/dev/null || true

echo -e "${GREEN}✓ Flatpak theming configured${NC}"

# ============================================
# VERIFICATION
# ============================================
echo ""
echo -e "${BLUE}📋 Verification:${NC}"
echo "   GTK Theme:    $(gsettings get org.gnome.desktop.interface gtk-theme 2>/dev/null || echo 'N/A')"
echo "   Icon Theme:   $(gsettings get org.gnome.desktop.interface icon-theme 2>/dev/null || echo 'N/A')"
echo "   Cursor:       $(gsettings get org.gnome.desktop.interface cursor-theme 2>/dev/null || echo 'N/A')"
echo "   Color Scheme: $(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || echo 'N/A')"
echo "   Shell Theme:  $(gsettings get org.gnome.shell.extensions.user-theme name 2>/dev/null || echo 'N/A')"
echo "   Accent Color: $(gsettings get org.gnome.desktop.interface accent-color 2>/dev/null || echo 'N/A')"

# ============================================
# DONE
# ============================================
echo ""
echo -e "${GREEN}✅ Catppuccin Mocha setup complete!${NC}"
echo ""
echo -e "${YELLOW}📝 Important next steps:${NC}"
echo "   1. Log out and log back in for all changes to take effect"
echo "   2. If shell theme doesn't apply, ensure User Themes extension is enabled:"
echo "      gnome-extensions enable user-theme@gnome-shell-extensions.gcampax.github.com"
echo ""
echo -e "${BLUE}📌 Useful commands:${NC}"
echo "   - Check extensions:     gnome-extensions list"
echo "   - Enable User Themes:   ujust install-gnome-extension user-themes"
echo "   - Re-apply theme:       ./apply-gnome-shell-theme.sh"
echo ""
