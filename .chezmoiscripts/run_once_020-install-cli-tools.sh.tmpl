#!/usr/bin/env bash
# Install cross-platform CLI tools via Homebrew
set -euo pipefail

# Ensure brew is available (installed in 010)
if ! command -v brew &>/dev/null; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null || /opt/homebrew/bin/brew shellenv)"
fi

TOOLS=(
    eza
    bat
    fd
    fzf
    ripgrep
    zoxide
    starship
    lazygit
    glow
    television
    thefuck
    gh
    btop
    tmux
    neovim
    yazi
)

for tool in "${TOOLS[@]}"; do
    brew list "$tool" &>/dev/null && continue
    echo "Installing $tool..."
    brew install "$tool"
done

echo "✓ CLI tools installed"
