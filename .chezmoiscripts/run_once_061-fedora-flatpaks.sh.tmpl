#!/usr/bin/env bash
{{ if and (ne .flavor "fedora-atomic") (ne .flavor "arch") (ne .flavor "debian") }}exit 0{{ end }}
set -euo pipefail

# Install flatpak if not present (fedora-atomic/fedora have it natively)
if ! command -v flatpak &>/dev/null; then
    echo "Installing flatpak..."
    {{- if eq .flavor "arch" }}
    sudo pacman -S --noconfirm flatpak
    {{- else if eq .flavor "debian" }}
    sudo apt install -y flatpak
    {{- end }}
fi

flatpak remote-add --user --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

FLATPAKS=(
    com.spotify.Client
    app.zen_browser.zen
)

for app in "${FLATPAKS[@]}"; do
    flatpak info "$app" &>/dev/null && continue
    echo "Installing $app..."
    flatpak install --user -y flathub "$app"
done

echo "✓ Flatpaks installed (Spotify, Zen Browser)"
